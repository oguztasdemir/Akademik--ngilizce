{
  "version": 2,
  "builds": [
    {
      "src": "Web Gui/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "api/server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "Dataset/**",
          "Web Gui/pdfs/**"
        ]
      }
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/server.js"
    },
    {
      "src": "/pdfs/(.*)",
      "dest": "api/server.js"
    },
    {
      "src": "/dataset/(.*)",
      "dest": "api/server.js"
    },
    {
      "src": "/assets/(.*)",
      "dest": "Web Gui/assets/$1"
    },
    {
      "src": "/(.*)\\.(js|css|png|jpg|jpeg|gif|ico|svg|json|pdf|txt)",
      "dest": "Web Gui/$1.$2"
    },
    {
      "src": "/(.*)",
      "dest": "Web Gui/index.html"
    }
  ]
}
